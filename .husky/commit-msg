# Enforce Conventional Commits: type(scope)?: subject
if ! head -1 "$1" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?!?: .{1,100}$'; then
  echo "" >&2
  echo "Commit message must follow Conventional Commits, e.g.:" >&2
  echo "  feat: add product card component" >&2
  echo "  fix(cart): prevent negative quantities" >&2
  exit 1
fi
