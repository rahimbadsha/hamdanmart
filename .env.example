# Copy this file to .env and adjust values. Never commit .env.

# SQLite database file (development). Path is relative to the project root.
# For PostgreSQL later: postgresql://user:password@host:5432/hamdanmart
DATABASE_URL="file:./prisma/dev.db"

# Absolute URL the app is served from.
APP_URL="http://localhost:3000"

# SMTP (production only — dev uses console transport)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="HamdanMart <noreply@hamdanmart.com>"
